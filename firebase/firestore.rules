rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function own(uid) { return signedIn() && request.auth.uid == uid; }
    function isAdmin() {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{uid} {
      allow read: if own(uid) || isAdmin();
      allow create: if own(uid);
      allow update: if own(uid) || isAdmin();
      allow delete: if isAdmin();
    }
    match /lessons/{lessonId} {
      allow read: if signedIn() && (resource.data.published == true || isAdmin());
      allow write: if isAdmin();
    }
    match /quizzes/{quizId} {
      allow read: if signedIn() && (resource.data.published == true || isAdmin());
      allow write: if isAdmin();
      match /questions/{questionId} { allow read: if signedIn(); allow write: if isAdmin(); }
    }
    match /progress/{uid}/items/{itemId} { allow read, write: if own(uid) || isAdmin(); }
    match /quizDrafts/{uid}/attempts/{attemptId} { allow read, write: if own(uid) || isAdmin(); }
    match /quizAttempts/{attemptId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }
    match /analytics/{document=**} { allow read: if isAdmin(); allow write: if false; }
  }
}
